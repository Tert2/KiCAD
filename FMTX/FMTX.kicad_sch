	(text "75-80 MHz FM transmitter\nFundmental Freq f_{f} = 26.39 * 3 MHz\nCrystal Freq: 23.3 < f < 33.3\nC_{6} = 1/((2*pi*f_{f})^2*L_{2})\nC_{9} = 1/((2*pi*f_{f})^2*L_{3})\nInput voltage sloud be lower than 1 V\nIn this cases, C_{6} = 18.3695p, C_{9} = 40.4128p"
		(exclude_from_sim no)
		(at 184.15 173.99 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "d45ac657-aea9-4235-ab0d-45878892aed5")
	)
